# Copy this to .env and fill in your values

# Groq API — https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Firebase — https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gumroad — Product permalinks (the slug from your product URL)
# e.g. if URL is gumroad.com/l/legalcheck-single → permalink is legalcheck-single
VITE_GUMROAD_SINGLE_LINK=https://your_name.gumroad.com/l/your-single-product
VITE_GUMROAD_LIFETIME_LINK=https://your_name.gumroad.com/l/your-lifetime-product
VITE_GUMROAD_SINGLE_PERMALINK=your-single-product-permalink
VITE_GUMROAD_LIFETIME_PERMALINK=your-lifetime-product-permalink
